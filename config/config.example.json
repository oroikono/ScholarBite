{
  "providers": {
    "openrouter": {
      "apiKey": "${OPENROUTER_API_KEY}"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.nanobot/workspace",
      "model": "anthropic/claude-sonnet-4-20250514",
      "provider": "openrouter",
      "maxTokens": 8192,
      "temperature": 0.5,
      "maxToolIterations": 30
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "bot_token": "${SLACK_BOT_TOKEN}",
      "app_token": "${SLACK_APP_TOKEN}",
      "allow_from": []
    },
    "whatsapp": {
      "enabled": false
    }
  }
}
